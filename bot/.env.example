# Скопируй этот файл в bot/.env и заполни значения.
# bot/.env в .gitignore — в репозиторий не попадёт.

# Токен бота (тот, что перевыпустил через /revoke)
BOT_TOKEN=

# Адрес кошелька-продавца (на него приходят оплаты).
# Для теста это твой же кошелёк. Скопируй из Tonkeeper → Receive.
MERCHANT_ADDRESS=
